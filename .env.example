# Guild AI — Environment Variables
# Copy to .env and fill in real values

# GCP / Vertex AI
GCP_PROJECT_ID=guild-ai-080
GCP_LOCATION=us-central1
GEMINI_FLASH_MODEL=gemini-2.0-flash-001
GEMINI_PRO_MODEL=gemini-2.0-pro-001

# Anthropic (fallback LLM — optional but recommended)
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/guild

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333

# Firebase
FIREBASE_PROJECT_ID=guild-ai-080
# Set GOOGLE_APPLICATION_CREDENTIALS env var to your Firebase service account JSON

# Paystack (billing)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Security
SECRET_KEY=changeme-to-a-random-string-in-production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# App
APP_ENV=local
DEBUG=true
