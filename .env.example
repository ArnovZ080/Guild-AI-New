# ── Guild AI Environment Variables ──
# Copy this file to .env and fill in your values

# App
APP_NAME=Guild AI
APP_ENV=local                # local | staging | production
DEBUG=true                   # Set false in production
SECRET_KEY=changeme          # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# GCP / Vertex AI (required — LLM and media generation)
GCP_PROJECT_ID=guild-ai-080
GCP_LOCATION=us-central1
GEMINI_FLASH_MODEL=gemini-2.0-flash-001
GEMINI_PRO_MODEL=gemini-2.0-pro-001

# Anthropic (fallback only — optional)
ANTHROPIC_API_KEY=

# Database — Supabase (free tier) for beta
# https://supabase.com → create project → Settings → Database → Connection string
# Format: postgresql+asyncpg://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/guild

# Redis — Upstash free tier for beta
# https://upstash.com → create database → copy Redis URL
# Format: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qdrant — Qdrant Cloud free tier for beta
# https://cloud.qdrant.io → create cluster → copy URL + API key
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Supabase (Storage for media files)
# https://supabase.com → project → Settings → API
SUPABASE_URL=https://jypdcueqaoaxuqojwhnn.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=media

# Firebase Auth
FIREBASE_PROJECT_ID=guild-ai-080

# Paystack Billing
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Media Storage
MEDIA_UPLOAD_DIR=./uploads/media
STORAGE_BACKEND=local        # "local" for dev, "supabase" for beta/production
MAX_UPLOAD_SIZE_MB=25

# ── Frontend (Vite) ──
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=guild-ai-080.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=guild-ai-080
VITE_FIREBASE_STORAGE_BUCKET=guild-ai-080.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
